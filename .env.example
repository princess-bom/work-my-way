# Release runtime configuration
# Copy to the deployment environment; do not commit real secrets.

# PostgreSQL connection used by the Express API and migrations.
DATABASE_URL=postgres://user:password@localhost:5432/kkumideun

# Required outside tests/smoke helpers. Use high-entropy random values.
SESSION_SECRET=replace-with-random-session-secret
SERVER_ENCRYPTION_KEY=replace-with-random-encryption-key

# API and single-origin deployment settings.
API_PORT=8787
NODE_ENV=production
