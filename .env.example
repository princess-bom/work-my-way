# Server-side only. Never expose this value through a VITE_ variable.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
OPENAI_REALTIME_MODEL=gpt-realtime-2.1-mini

# Optional durable server persistence. Without this, local development can use
# process memory; a serverless deployment is surfaced to the browser as a
# device fallback because function memory is not durable across requests.
POSTGRES_URL=
