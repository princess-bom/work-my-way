{
  "name": "eiden-pathways",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node e2e/smoke.mjs",
    "check:english": "node scripts/check-english.mjs",
    "check:secrets": "node scripts/check-client-secrets.mjs",
    "verify": "npm run check:english && npm run test && npm run build && npm run check:secrets && npm run test:e2e"
  },
  "dependencies": {
    "lucide-react": "^0.560.0",
    "openai": "^6.48.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "playwright": "^1.61.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
